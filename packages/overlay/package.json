{
  "name": "@stoat-run/overlay",
  "version": "0.1.1",
  "private": false,
  "license": "MIT",
  "author": "sic-em",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sic-em/stoat.run.git",
    "directory": "packages/overlay"
  },
  "homepage": "https://github.com/sic-em/stoat.run/tree/main/packages/overlay",
  "bugs": {
    "url": "https://github.com/sic-em/stoat.run/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/StoatOverlay.d.ts",
      "import": "./dist/StoatOverlay.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.cts",
      "require": "./dist/middleware.cjs",
      "default": "./dist/middleware.cjs"
    },
    "./meta": {
      "types": "./dist/meta.d.cts",
      "require": "./dist/meta.cjs",
      "default": "./dist/meta.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18",
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/express": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
