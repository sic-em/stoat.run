{
  "name": "ferret",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:cp": "pnpm --filter @ferret/control-plane dev",
    "dev:cli": "pnpm --filter ferret dev",
    "build:gateway": "cd gateway && go build -o ../dist/ferret-gateway .",
    "test:e2e:local": "bash scripts/e2e-local.sh",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20"
  }
}
